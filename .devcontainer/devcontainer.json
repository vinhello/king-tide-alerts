{
  "name": "King Tide Alert",
  "dockerFile": "Dockerfile",
  "workspaceFolder": "/workspace",
  "runArgs": ["--cap-add=NET_ADMIN"],
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "source=claude-gh-credentials,target=/home/node/.config/gh,type=volume",
    "source=claude-npm-cache,target=/home/node/.npm,type=volume",
    "source=claude-pip-cache,target=/home/node/.cache/pip,type=volume",
    "source=claude-history,target=/home/node/.bash_history_dir,type=volume"
  ],
  "postCreateCommand": "bash /workspace/.devcontainer/setup-container.sh",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "notify" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
